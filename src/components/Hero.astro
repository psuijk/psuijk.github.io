---
import { render } from 'astro:content';

interface Props {
  name: string;
  tagline: string[];
  supporting: string;
  links: { label: string; href: string }[];
}

const { name, tagline, supporting, links } = Astro.props;
---

<section class="min-h-screen flex flex-col justify-center px-6" style="animation: fadeIn 0.6s ease-out both;">
  <div class="max-w-3xl mx-auto w-full">
    <p class="text-[var(--color-muted)] text-sm tracking-wide uppercase mb-12 font-medium">{name}</p>

    <div class="mb-8">
      {tagline.map((phrase) => (
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold leading-tight tracking-tight">{phrase}</h1>
      ))}
    </div>

    <p class="text-lg text-[var(--color-muted)] mb-16 max-w-xl">{supporting}</p>

    <nav class="flex gap-6 flex-wrap">
      <a
        href="#projects"
        class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
      >
        Projects
      </a>
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
          target={link.href.startsWith('http') || link.href.startsWith('mailto') ? '_blank' : undefined}
          rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</section>

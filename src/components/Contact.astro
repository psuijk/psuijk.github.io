---
interface Props {
  heading: string;
  content: string;
}

const { heading, content } = Astro.props;
---

<section class="px-6 py-24">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-semibold mb-8 tracking-tight">{heading}</h2>
    <div class="prose" set:html={content} />
  </div>
</section>

<style>
  .prose {
    color: var(--color-text);
    line-height: 1.7;
  }
  .prose :global(p) {
    margin-bottom: 1em;
  }
  .prose :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5em;
  }
  .prose :global(li) {
    font-size: 0.875rem;
  }
  .prose :global(a) {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .prose :global(a:hover) {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>

---
interface Props {
  heading: string;
  intro: string;
  content: string;
}

const { heading, intro, content } = Astro.props;
---

<section class="px-6 py-12">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl font-semibold mb-3 tracking-tight">{heading}</h2>
    <p class="text-sm text-[var(--color-muted)] mb-8">{intro}</p>
    <div class="prose" set:html={content} />
  </div>
</section>

<style>
  .prose {
    color: var(--color-text);
    line-height: 1.7;
  }
  .prose :global(h2) {
    font-size: 1.1rem;
    font-weight: 500;
    margin-top: 2em;
    margin-bottom: 0.75em;
    color: var(--color-text);
  }
  .prose :global(h2:first-child) {
    margin-top: 0;
  }
  .prose :global(p) {
    margin-bottom: 1em;
  }
  .prose :global(em) {
    color: var(--color-muted);
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }
  .prose :global(a:hover) {
    text-decoration: underline;
  }
</style>
